# TFT Auto Chess Configuration

# Game Settings
GAME_WINDOW_NAME=League of Legends
SCREENSHOT_INTERVAL=1

# Model Settings
USE_GPU=True
GPU_DEVICE=0

# Feature Flags
ENABLE_AUTO_RECOMMENDATION=True
ENABLE_AUTO_CLICK=False
ENABLE_WEB_UI=True
ENABLE_REAL_TIME_MONITORING=True

# Debug Settings
DEBUG_MODE=False
LOG_LEVEL=INFO

# Flask API
FLASK_HOST=127.0.0.1
FLASK_PORT=5000